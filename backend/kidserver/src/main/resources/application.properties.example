# application.properties 예시 파일
# 실제 사용 시 이 파일을 복사하여 application.properties로 사용하거나
# 환경 변수로 설정하세요.

spring.application.name=kidspoint-server

# 데이터베이스 설정
spring.datasource.url=jdbc:postgresql://localhost:5432/postgres?currentSchema=kidspoint
spring.datasource.username=postgres
spring.datasource.password=your_password_here
spring.datasource.driver-class-name=org.postgresql.Driver

spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.connection-timeout=30000
spring.datasource.hikari.idle-timeout=600000
spring.datasource.hikari.max-lifetime=1800000

# Spring Session JDBC
spring.session.store-type=jdbc
spring.session.jdbc.initialize-schema=never
spring.session.timeout=30m
server.servlet.session.cookie.name=SESSION
server.servlet.session.cookie.http-only=true
server.servlet.session.cookie.secure=false
server.servlet.session.cookie.same-site=lax
server.servlet.session.cookie.domain=

server.port=${PORT:8080}

# 정적 리소스 설정
spring.web.resources.add-mappings=false

# MyBatis 설정
mybatis.mapper-locations=classpath:mapper/**/*.xml
mybatis.type-aliases-package=com.kidspoint.api
mybatis.configuration.map-underscore-to-camel-case=true
mybatis.configuration.default-fetch-size=100
mybatis.configuration.default-statement-timeout=30

# 로깅 레벨 설정
logging.level.com.kidspoint=DEBUG
logging.level.com.kidspoint.api.auth=DEBUG
logging.level.com.kidspoint.api.kids=DEBUG
logging.level.org.springframework.web=DEBUG
logging.level.org.springframework.security=DEBUG
logging.level.org.mybatis=DEBUG
logging.level.org.springframework.jdbc.core=DEBUG

# 카카오 로그인 설정
kakao.client-id=${KAKAO_CLIENT_ID:your_kakao_rest_api_key}
kakao.client-secret=${KAKAO_CLIENT_SECRET:your_kakao_client_secret}
kakao.redirect-uri=${KAKAO_REDIRECT_URI:http://localhost:8080/api/auth/kakao/callback}
kakao.frontend-redirect-uri=${KAKAO_FRONTEND_REDIRECT_URI:http://localhost:5173}
kakao.native-app-key=${KAKAO_NATIVE_APP_KEY:your_kakao_native_app_key}

# 구글 로그인 설정
google.client-id=${GOOGLE_CLIENT_ID:your_google_client_id}
google.client-secret=${GOOGLE_CLIENT_SECRET:your_google_client_secret}
google.redirect-uri=${GOOGLE_REDIRECT_URI:http://localhost:8080/api/auth/google/callback}
google.frontend-redirect-uri=${GOOGLE_FRONTEND_REDIRECT_URI:http://localhost:5173}

# 프론트엔드 URL 설정
app.frontend-url=${APP_FRONTEND_URL:http://localhost:5173}

# 파일 업로드 설정
app.upload.dir=${UPLOAD_DIR:/data/uploads/items}
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
